<!DOCTYPE html>
<html>
<head>
    <title>Employee Table</title>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <style>
        table {
            border-collapse: collapse;
            width: 70%;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: center;
        }
        .odd-row {
            background-color: lightgreen;
        }
    </style>
</head>

<body ng-app="myApp" ng-controller="empCtrl">

<h2>Employee Data</h2>

<table>
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Salary</th>
    </tr>

    <tr ng-repeat="emp in employees"
        ng-class-odd="'odd-row'">

        <td>{{ emp.id }}</td>
        <td>{{ emp.name }}</td>
        <td>{{ emp.salary }}</td>
    </tr>
</table>

<script>
var app = angular.module("myApp", []);

app.controller("empCtrl", function($scope) {
    $scope.employees = [
        { id:101, name:"Raj", salary:30000 },
        { id:102, name:"Simran", salary:35000 },
        { id:103, name:"Amit", salary:28000 },
        { id:104, name:"Neha", salary:40000 },
        { id:105, name:"Rohan", salary:32000 },
        { id:106, name:"Priya", salary:36000 },
        { id:107, name:"Karan", salary:29000 },
        { id:108, name:"Sneha", salary:31000 },
        { id:109, name:"Rahul", salary:33000 },
        { id:110, name:"Pooja", salary:37000 }
    ];
});
</script>

</body>
</html>